{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "description": "The name of the experiment",
      "type": "string"
    },
    "platform": {
      "description": "The platforms listed in the command",
      "type": "string"
    },
    "target": {
      "description": "The targets listed in the command",
      "type": "string"
    },
    "directories": {
      "description": "FRE shared directories",
      "$ref": "#/$defs/dirs"
    },
    "postprocess": {
      "description": "FRE post-processing information",
      "$ref": "#/$defs/Postprocess"
    },
    "final-step-user-scripts": {
      "description": "User scripts previously known as analysis scripts that act on postprocessed output",
      "$ref": "#/$defs/Analysis"
    },
    "fre_properties": {
      "description": "User-defined variables",
      "type": "array"
    },
    "build": {
      "description": "Dummy placeholder so additionalProperties can be false"
    }
  },
  "required": [
    "name",
    "platform",
    "target",
    "directories",
    "postprocess"
  ],
  "additionalProperties": false,
  "$defs": {
    "dirs": {
      "type": "object",
      "properties": {
        "history_dir": {
          "description": "Directory path to raw model output.",
          "type": "string"
        },
        "refined_history_dir": {
          "description": "Directory path for netCDF files created via refinediag scripts.",
          "type": "string"
        },
        "pp_dir": {
          "description": "Directory path to post-processing output.",
          "type": "string"
        },
        "ptmp_dir": {
          "description": "Directory to use for history file cache.",
          "type": "string"
        },
        "analysis_dir": {
          "description": "Directory path to analysis scripts.",
          "type": "string"
        }
      },
      "required": [
        "history_dir",
        "pp_dir",
        "ptmp_dir"
      ],
      "additionalProperties": false
    },
    "Postprocess": {
      "type": "object",
      "properties": {
        "settings": {
          "type": "object",
          "properties": {
            "history_segment": {
              "description": "Amount of time covered by a single history file (ISO8601 datetime)",
              "type": "string",
              "pattern": "^P[0-9]+[M|Y]$"
            },
            "site": {
              "description": "Site name from file that defines parameters that can be specific to where the workflow is being run.",
              "type": "string"
            },
            "pp_chunks": {
              "description": "Array of chunk sizes to create",
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "description": "ISO8601 duration string representing the length, in units of model time, of postprocessed files",
                "type": "string",
                "pattern": "^P[0-9]+[M|Y]$"
              }
            },
            "pp_start": {
              "description": "Start of the desired postprocessing (ISO8601 datetime or YYYY).",
              "type": "string",
              "pattern": "(^[0-9]{4}$)|(^[0-9]{8}T[0-9]{4}Z$)"
            },
            "pp_stop": {
              "description": "End of the desired postprocessing (ISO8601 datetime or YYYY).",
              "type": "string",
              "pattern": "(^[0-9]{4}$)|(^[0-9]{8}T[0-9]{4}Z$)"
            },
            "pp_grid_spec": {
              "description": "Path to FMS grid definition tarfile.",
              "type": "string"
            }
          },
          "required": [
            "history_segment",
            "site",
            "pp_chunks",
            "pp_start",
            "pp_stop",
            "pp_grid_spec"
          ],
          "additionalProperties": false
        },
        "switches": {
          "type": "object",
          "properties": {
            "clean_work": {
              "description": "Switch to remove intermediate data files when they are no longer needed.",
              "type": "boolean"
            },
            "do_atmos_plevel_masking": {
              "description": "Switch to mask atmos pressure-level output above/below surface pressure/atmos top.",
              "type": "boolean"
            },
            "do_workflow_email": {
              "description": "Switch to turn on Cylc scheduler emails",
              "type": "boolean",
              "default": "false"
            }
          },
          "required": [
            "clean_work",
            "do_atmos_plevel_masking"
          ],
          "additionalProperties": false
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "description": "Component name",
                "type": "string"
              },
              "sources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                                  "history_file": {
                                    "description": "History files to include in this component",
                                    "type": "string"
                                  },
                                  "variables": {
                                    "type": "array",
                                    "items": {"type": "string"}
                                  }
                                },
                  "additionalProperties": false
                },
                "required": ["history_file"]
              },
              "sourceGrid": {
                "description": "Input grid type.",
                "type": "string",
                "enum": [
                    "tripolar",
                    "cubedsphere"
                ]
              },
              "xyInterp": {
                "description": "Lat, lon grid configuration.",
                "type": "string"
              },
              "interpMethod": {
                "description": "The interpolation method. Required if regridding.",
                "type": "string",
                "enum": [
                  "conserve_order1",
                  "conserve_order2",
                  "bilinear"
                ]
              },
              "inputRealm": {
                "description": "Domain of component.",
                "type": "string",
                "enum": [
                    "atmos",
                    "ocean",
                    "land"
                ]
              },
              "climatology": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "frequency": {
                      "description": "Monthly or annual climatology ('yr' or 'mon')",
                      "type": "string",
                      "enum": [
                        "yr",
                        "mon"
                      ]
                    },
                    "interval_years": {
                      "description": "Climatology interval in years",
                      "type": "integer"
                    }
                  },
                  "required": [
                    "frequency",
                    "interval_years"
                  ],
                  "additionalProperties": false
                },
                "minItems": 1,
                "uniqueItems": true
              },
              "static": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "variables": {
                      "description": "Variables included in sources",
                      "type": "array",
                      "items": {"type": "string"}
                    }
                  },
                  "unevaluatedProperties": false,
                  "oneOf": [ {"type": "object",
                              "properties": {
                                "source": {
                                  "description": "History files to include in this component",
                                  "type": "string"
                                }
                              },
                              "required": ["source"]
                             },
                             {"type": "object",
                              "properties": {
                                "offline_source": {
                                  "description": "Path to static offline diagnostic",
                                  "type": "string"
                                }
                              },
                              "required": ["offline_source"]
                             }
                           ]
                },
                "additionalProperties": false
              },
              "postprocess_on": {
                "type": "boolean",
                "default": "True"
              }
            },
            "required": [
              "type",
              "sources"
            ],
            "dependentRequired": {
              "xyInterp": ["inputRealm", "sourceGrid", "interpMethod"]
            },
            "additionalProperties": false
          }
        },
        "first-step-user-scripts": {
          "description": "User-specified cshell script to run on history files, their expected input history file names, and a switch",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "script": {
                "description": "Absoute filepath to the script",
                "type": "string"
              },
              "user_script_on": {
                "description": "Switch to run the script",
                "type": "boolean",
                "default": "True"
              },
              "inputs": {
                "description": "List of input history files the script requires",
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "script"
            ],
            "additionalProperties": false
          }
        },
        "refinediag-user-scripts": {
          "description": "User-specified cshell script to run on history files and produce new history files to postprocess, their expected input and output history file names, and a switch",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "script": {
                "description": "Absolute filepath to the script",
                "type": "string"
              },
              "user_script_on": {
                "description": "Switch to run the script",
                "type": "boolean",
                "default": "True"
              },
              "inputs": {
                "description": "List of input history files the script requires",
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "outputs": {
                "description": "List of output history files produced by the script",
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "script"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "components",
        "settings",
        "switches"
      ],
      "additionalProperties": false
    },
    "Analysis": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "properties": {
            "user_script_on": {
              "description": "Switch to enable or disable this script without removing it",
              "type": "boolean",
              "default": true
            },
            "trigger": {
              "description": "When and for which components to run the script",
              "type": "object",
              "properties": {
                "components": {
                  "description": "List of postprocess components required by this script",
                  "type": "array",
                  "items": {"type": "string"},
                  "minItems": 1
                },
                "interval": {
                  "description": "How often to run the script (ISO8601 duration)",
                  "type": "string",
                  "pattern": "^P[0-9]+[MY]$"
                },
                "when_to_run": {
                  "description": "Whether the script processes each chunk independently, cumulatively, or runs once after all chunks are ready",
                  "type": "string",
                  "enum": ["independent", "cumulative", "one-shot"]
                }
              },
              "required": ["components", "interval", "when_to_run"],
              "additionalProperties": false
            },
            "install": {
              "description": "How to install and run the script",
              "type": "object",
              "oneOf": [
                {
                  "properties": {
                    "method": {"const": "legacy"},
                    "path": {
                      "description": "Absolute path to the script",
                      "type": "string"
                    }
                  },
                  "required": ["method", "path"],
                  "additionalProperties": false
                },
                {
                  "properties": {
                    "method": {"const": "pip"},
                    "package": {
                      "description": "Pip package name",
                      "type": "string"
                    },
                    "version": {
                      "description": "Pip package version constraint",
                      "type": "string"
                    },
                    "entry_point": {
                      "description": "Specific callable or console script to invoke",
                      "type": "string"
                    }
                  },
                  "required": ["method", "package"],
                  "additionalProperties": false
                }
              ]
            },
            "data": {
              "description": "Data requirements; required for legacy scripts",
              "type": "object",
              "properties": {
                "frequency": {
                  "description": "Required data frequency",
                  "type": "string"
                },
                "type": {
                  "description": "Required data type (e.g. timeseries, climatology)",
                  "type": "string"
                }
              },
              "required": ["frequency", "type"],
              "additionalProperties": false
            },
            "config": {
              "description": "Script-internal configuration passed through to the script unchanged",
              "type": "object",
              "additionalProperties": true
            },
            "date_range": {
              "description": "Date range for analysis script, in two 4-digit string form, e.g. ['YYYY', 'ZZZZ']. Optional; will use postprocess start/stop if not specified.",
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[0-9]{4}$"
              },
              "minItems": 2,
              "maxItems": 2,
              "uniqueItems": false
            }
          },
          "required": ["trigger", "install"],
          "if": {
            "properties": {
              "install": {
                "properties": {"method": {"const": "legacy"}},
                "required": ["method"]
              }
            },
            "required": ["install"]
          },
          "then": {
            "required": ["trigger", "install", "data"]
          },
          "additionalProperties": false
        }
      }
    }
  }
}
